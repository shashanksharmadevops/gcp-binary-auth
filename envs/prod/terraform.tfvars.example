env = "prod"

# ── Project IDs ───────────────────────────────────────────────────────────
gar_project_id         = "my-gar-project"          # same shared GAR project
gke_project_id         = "my-prod-gke-project"
attestor_project_id    = "my-prod-attestor-project"
attestation_project_id = "my-prod-attestation-project"

# ── GAR ───────────────────────────────────────────────────────────────────
gar_location      = "us-central1"
gar_repository_id = "container-images"
gar_description   = "Shared container image registry"

# ── GKE clusters ──────────────────────────────────────────────────────────
clusters = {
  primary = {
    name         = "prod-primary"
    zone         = "us-central1-a"
    node_count   = 5
    machine_type = "e2-standard-4"
    enforcement_mode = "ENFORCED_BLOCK_AND_AUDIT_LOG"
  }
  secondary = {
    name         = "prod-secondary"
    zone         = "us-east1-b"
    node_count   = 5
    machine_type = "e2-standard-4"
    enforcement_mode = "ENFORCED_BLOCK_AND_AUDIT_LOG"
  }
}

# ── Attestors ─────────────────────────────────────────────────────────────
attestors = {
  build = {
    display_name     = "Build attestor"
    kms_keyring_name = "binauthz-keyring"
    kms_key_name     = "prod-build-signing-key"
    kms_location     = "global"
    kms_key_algorithm    = "EC_SIGN_P256_SHA256"
    kms_protection_level = "HSM"   # HSM in production
  }
  security-scan = {
    display_name     = "Security scan attestor"
    kms_keyring_name = "binauthz-keyring"
    kms_key_name     = "prod-security-scan-signing-key"
    kms_location     = "global"
    kms_key_algorithm    = "EC_SIGN_P256_SHA256"
    kms_protection_level = "HSM"
  }
  qa = {
    display_name     = "QA sign-off attestor"
    kms_keyring_name = "binauthz-keyring"
    kms_key_name     = "prod-qa-signing-key"
    kms_location     = "global"
    kms_key_algorithm    = "EC_SIGN_P256_SHA256"
    kms_protection_level = "HSM"
  }
}
